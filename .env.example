# Backend
DATABASE_URL=postgres://glob:glob@localhost:5432/glob
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d
COOKIE_SECURE=false
PORT=3001
CORS_ORIGIN=http://localhost:5173
USDA_API_KEY=DEMO_KEY
# Coach LLM (OpenAI-compatible). Default points at Groq's free tier — get a key at console.groq.com
LLM_API_KEY=gsk_...
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Frontend (Vite)
VITE_API_BASE_URL=/api/v1
