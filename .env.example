# Backend
DATABASE_URL=postgres://glob:glob@localhost:5432/glob
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d
COOKIE_SECURE=false
PORT=3001
CORS_ORIGIN=http://localhost:5173
USDA_API_KEY=DEMO_KEY
# Coach LLM (OpenAI-compatible). Default = a locally-hosted Ollama model (no API key, no rate limits).
# One-time setup:  ollama pull qwen2.5:7b-instruct
# Run the server with a large context so the prompt fits:  OLLAMA_CONTEXT_LENGTH=16384 ollama serve
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b-instruct
LLM_RESPONSE_FORMAT=json_schema
# Cloud alternative (e.g. Groq) — set LLM_RESPONSE_FORMAT=json_object since they lack constrained decoding:
# LLM_API_KEY=gsk_...
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_RESPONSE_FORMAT=json_object

# Frontend (Vite)
VITE_API_BASE_URL=/api/v1
